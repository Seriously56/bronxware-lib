                if alpha then 
                    a = alpha
                end 
                
                local Color = hsv(h, s, v)

                Items.SatValPicker.Position = dim2(s, -4, 1 - v, -4)
                Items.AlphaPicker.Position = dim2(0, 0, a, -1)
                Items.HuePicker.Position = dim2(0, -1, h, -1)
                
                Items.ButtonColor.BackgroundColor3 = hsv(h,s,v)
                Items.Inner.BackgroundColor3 = hsv(h,1,1)

                Flags[Cfg.Flag] = {
                    Color = Color;
                    color = Color;
                    Transparency = a;
                    transparency = a;
                }
                
                local Color = Items.ButtonColor.BackgroundColor3
                Items.RGBInput.Text = string.format("%s, %s, %s, %s", 
                    Library:Round(Color.R * 255), 
                    Library:Round(Color.G * 255), 
                    Library:Round(Color.B * 255),
                    Library:Round(1 - a, 0.01)
                )
                
