            local function UpdateSliderFromX(x)
                local absPos = Items.SliderBar.AbsolutePosition
                local absSize = Items.SliderBar.AbsoluteSize
                local rel = math.clamp((x - absPos.X) / absSize.X, 0, 1)
                local steps = (Cfg.Max - Cfg.Min)/Cfg.Intervals
                local steppedValue = math.floor(rel * steps + 0.5) / steps
                local value = Cfg.Min + ((Cfg.Max - Cfg.Min) * steppedValue)
                Cfg.Set(value)
            end

            Items.SliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Cfg.Dragging = true
                    local posX = input.UserInputType == Enum.UserInputType.Touch and input.Position.X or UserInputService:GetMouseLocation().X
                    UpdateSliderFromX(posX)
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if Cfg.Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local posX = input.UserInputType == Enum.UserInputType.Touch and input.Position.X or UserInputService:GetMouseLocation().X
                    UpdateSliderFromX(posX)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Cfg.Dragging = false
                end
            end)

            function Cfg.Set(value)
                Cfg.Value = Library:Round(value, Cfg.Intervals)
                Items.Fill.Size = dim2((Cfg.Value - Cfg.Min) / (Cfg.Max - Cfg.Min), 0, 1, 0)
                Items.Value.Text = tostring(Cfg.Value) .. Cfg.Suffix
                Flags[Cfg.Flag] = Cfg.Value
                Cfg.Callback(Flags[Cfg.Flag])
            end

            Cfg.Set(Cfg.Value)
            ConfigFlags[Cfg.Flag] = Cfg.Set

            return setmetatable(Cfg, Library)
        end 

