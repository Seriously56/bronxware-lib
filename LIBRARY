                    local Mouse = InputService:GetMouseLocation()
                    pos = vec2(Mouse.X, Mouse.Y - gui_offset)
                end

                if DraggingSat then	
                    s = math.clamp((pos.X - Items.Val.AbsolutePosition.X) / Items.Val.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((pos.Y - Items.Val.AbsolutePosition.Y) / Items.Val.AbsoluteSize.Y, 0, 1)
                elseif DraggingHue then
                    h = math.clamp((pos.Y - Items.RGB.AbsolutePosition.Y) / Items.RGB.AbsoluteSize.Y, 0, 1)
